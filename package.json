{
  "name": "draw-guess",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev -w draw-guess-server\" \"npm run dev -w draw-guess-client\"",
    "build": "npm run build -w draw-guess-client",
    "start": "npm run start -w draw-guess-server",
    "install:all": "npm install"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
